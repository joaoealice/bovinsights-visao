# Copie este arquivo para .env e preencha os valores

# Roboflow — Detecção de comportamento
ROBOFLOW_API_KEY=sua_api_key_aqui
ROBOFLOW_MODEL_ID=cattle-dataset-behavior-cqtzu
ROBOFLOW_MODEL_VERSION=1

# Roboflow — Contagem de animais
ROBOFLOW_COUNT_MODEL_ID=cow-count
ROBOFLOW_COUNT_MODEL_VERSION=2

# Roboflow — Upload de frames para treino
ROBOFLOW_WORKSPACE=grupo-j-f-business
ROBOFLOW_PROJECT=bovinos-confinamento

# API
API_ENV=development
API_SECRET_KEY=troque_em_producao
MAX_IMAGE_SIZE_MB=5
INFERENCE_INTERVAL_SECONDS=3

# CORS — em produção use a URL do Render
ALLOWED_ORIGINS=http://localhost:8000,https://SEU_APP.onrender.com
